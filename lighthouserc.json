{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8080/index.html",
        "http://localhost:8080/pages/about/index.html",
        "http://localhost:8080/pages/elements/color.html",
        "http://localhost:8080/pages/elements/typography.html",
        "http://localhost:8080/pages/components/button.html",
        "http://localhost:8080/pages/components/modal.html",
        "http://localhost:8080/pages/components/index.html",
        "http://localhost:8080/pages/dataviz/types.html",
        "http://localhost:8080/pages/dataviz/examples.html",
        "http://localhost:8080/pages/guidelines/accessibility.html"
      ],
      "numberOfRuns": 1,
      "startServerCommand": "python -m http.server 8080",
      "startServerReadyPattern": "Serving HTTP",
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":   ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices":["warn", { "minScore": 0.90 }],
        "categories:seo":           ["warn", { "minScore": 0.90 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
